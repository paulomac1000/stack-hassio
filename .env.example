# ==============================================================================
# DOCKER COMPOSE ENVIRONMENT VARIABLES
# Skopiuj ten plik do .env i uzupełnij prawdziwymi wartościami
# NIGDY nie commituj .env do repozytorium!
# ==============================================================================

# Cloudflare Tunnel
TUNNEL_TOKEN=your_cloudflare_tunnel_token

# MQTT
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Home Assistant (dla integracji)
HA_LONG_LIVED_TOKEN=your_long_lived_access_token

# go2rtc API and RTSP password (used by HA's built-in go2rtc instance)
GO2RTC_PASSWORD=your_go2rtc_password

# Zigbee2MQTT network encryption key (16-byte array as JSON)
# Get the current key from data/z2m/configuration.yaml before removing it
Z2M_NETWORK_KEY=[your,16,byte,zigbee,network,key,as,integers]

# Timezone
TZ=Europe/Warsaw

# FBService
FBSERVICE_CITY=your_city
FBSERVICE_STREET=your_street
FBSERVICE_NUMBER=your_number
